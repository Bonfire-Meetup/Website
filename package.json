{
  "name": "bnf-homepage-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "check": "oxlint . && oxfmt --check . && tsc --noEmit",
    "fix": "oxlint --fix . && oxfmt --write .",
    "postinstall": "mkdir -p public/vendor && cp node_modules/zxing-wasm/dist/reader/zxing_reader.wasm public/vendor/",
    "clean": "bun pm cache rm && rm -rf node_modules bun.lock && bun install",
    "email:dev": "email dev --dir app/components/email",
    "photos:refresh-data": "node scripts/refresh-photo-albums-data.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@react-email/components": "1.0.12",
    "@reduxjs/toolkit": "^2.12.0",
    "@rollbar/react": "^1.0.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-query": "^5.100.11",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@yudiel/react-qr-scanner": "^2.6.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "botid": "^1.5.11",
    "drizzle-orm": "^0.45.2",
    "geist": "^1.7.1",
    "jose": "^6.2.3",
    "next": "^16.2.6",
    "next-intl": "^4.12.0",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "postcss": "^8.5.15",
    "qrcode": "^1.5.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-redux": "^9.3.0",
    "rollbar": "^3.1.0",
    "sharp": "^0.34.5",
    "stripe": "^22.1.1",
    "tailwindcss": "^4.3.0",
    "ua-parser-js": "^2.0.10",
    "web-haptics": "^0.0.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@react-email/preview-server": "5.2.10",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.59.4",
    "cssnano": "^8.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.66.0",
    "react-email": "6.1.5",
    "typescript": "^6.0.3"
  },
  "next-intl": {
    "locales": [
      "en",
      "cs"
    ],
    "defaultLocale": "en",
    "localePrefix": "never"
  }
}
